      "item": [
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/list-jobs-ajax?user_id={{user_id}}&token={{token}}&draw={{draw}}&start={{start}}&length={{length}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "list-jobs-ajax"
              ],
              "query": [
                {
                  "key": "user_id",
                  "value": "{{user_id}}"
                },
                {
                  "key": "token",
                  "value": "{{token}}"
                },
                {
                  "key": "draw",
                  "value": "{{draw}}"
                },
                {
                  "key": "start",
                  "value": "{{start}}"
                },
                {
                  "key": "length",
                  "value": "{{length}}"
                }
              ]
            },
            "description": "Matches jobsService.getList(draw, start, length)."
          }
        },
